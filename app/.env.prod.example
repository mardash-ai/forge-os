# Generated by Forge — Productionize. Production config for forge-os.
# Copy to .env.prod, fill in real values, and DO NOT commit .env.prod.
# Consumed at deploy time (e.g. `docker compose -f compose.prod.yaml --env-file .env.prod ...`).
# Public host (baked into compose.prod.yaml Traefik labels): forge-os.mardash.ai
# Full operator guide + how to obtain each value: PROVISIONING.md (this app) and forge/PROVISIONING.md.

# --- Forge secrets vault master key (C5) ---
# FORGE_SECRETS_KEY — Master key the data-plane sidecar uses to DECRYPT the app’s C5 secrets vault at rest.
#   C5 · Secrets vault (master key) · Required. Required whenever the app uses any secret or the agent runtime (C1). Use the SAME key the secrets were sealed under — rotating it orphans the vault.
#   Obtain: Generate once, store securely, reuse across deploys.
#   Generate: openssl rand -base64 32
FORGE_SECRETS_KEY=change-me

# --- Postgres (required when the app is provisioned with a database) ---
# POSTGRES_PASSWORD — Password for the app’s Postgres role (user `forge`); also builds DATABASE_URL.
#   Datastore (Postgres) · Conditional. Required when the app is provisioned WITH a database (compose has a `postgres` service).
#   Obtain: Generate a strong random password; use the SAME value the DB was initialized with.
#   Generate: openssl rand -base64 24
POSTGRES_PASSWORD=change-me

# --- Declared secrets (injected into the web AND data-plane containers; never commit real values) ---
# ANTHROPIC_API_KEY — Anthropic API key the agent runtime uses to call the model.
#   C1 · Agent runtime (model access) · Conditional. Required only if the app uses C1 agent-run; without it agent-run degrades detectably (503).
#   Obtain: Create a key at the Anthropic Console (console.anthropic.com → API Keys).
ANTHROPIC_API_KEY=

# AUTH_SESSION_SECRET — HMAC key that SIGNS and VERIFIES the `forge_session` access token (P8).
#   C10 · Identity/Auth (session signing) · Conditional. Required for C10 auth. Without it sign-in is cleanly unavailable (503). The SAME value must reach both the data-plane (signs) and the app (verifies).
#   Obtain: Generate a strong random secret; keep it stable (rotating it invalidates all live sessions).
#   Generate: openssl rand -base64 48
AUTH_SESSION_SECRET=

# AUTH_SERVICE_TOKEN — Shared token a non-user principal (the C2 scheduler / cron) presents to reach service-authenticated endpoints.
#   C10 · Identity/Auth (service/cron principal) · Optional. Optional — needed only if the app has service-authenticated cron routes (`/api/cron/*`). Unset ⇒ those stay gated (401), detectably.
#   Obtain: Generate a high-entropy random token.
#   Generate: openssl rand -hex 32
AUTH_SERVICE_TOKEN=

# GOOGLE_CLIENT_ID — OAuth 2.0 Web client ID for "Continue with Google".
#   C10 · Identity/Auth (Google sign-in) · Optional. Optional — enables Google sign-in (no email dependency). Needs BOTH GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET; either alone leaves Google disabled.
#   Obtain: Google Cloud Console → APIs & Services → Credentials → Create credentials → OAuth client ID → type "Web application". Add the Authorized redirect URI `https://<host>/auth/google/callback`. Copy the Client ID (ends in `.apps.googleusercontent.com`).
GOOGLE_CLIENT_ID=

# GOOGLE_CLIENT_SECRET — OAuth 2.0 Web client secret paired with GOOGLE_CLIENT_ID.
#   C10 · Identity/Auth (Google sign-in) · Optional. Optional — enables Google sign-in. Needs BOTH creds; either alone leaves Google disabled.
#   Obtain: From the same Google Cloud OAuth 2.0 Web client as GOOGLE_CLIENT_ID (shown once on creation; you can add a new secret later).
GOOGLE_CLIENT_SECRET=

# SMTP_URL — SMTP connection URL used to send email (verify / password-reset links).
#   C12 · Transactional email · Optional. Optional — enables email/password SIGN-UP + verification + password reset (C10 relies on C12 for these). Unset ⇒ email/password signup is blocked cleanly (503); Google sign-in still works if configured.
#   Obtain: Obtain SMTP credentials from your provider (e.g. an app password / API-SMTP creds). Format: `smtp://USER:PASSWORD@HOST:PORT` (URL-encode reserved chars in the password).
SMTP_URL=

# EMAIL_FROM — The From address (and optional display name) outbound email is sent as.
#   C12 · Transactional email · Optional. Optional — paired with SMTP_URL; required for email delivery to work. Use a domain you’re authorized to send from.
#   Obtain: Choose an address on a domain you control, e.g. `Acme <no-reply@acme.example>`.
EMAIL_FROM=

# --- Scheduled jobs (C2) ---
# forge.jobs.json is mounted into the data-plane sidecar and registered on boot — no env needed.

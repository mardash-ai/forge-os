# Production env for `docker compose -f compose.prod.yaml` (compose auto-reads .env).
# Copy to `.env` and adjust. Pin images by digest for reproducible prod (R1) —
# `:latest` is convenience only.

APP_IMAGE=ghcr.io/mardash-ai/forge-os-app:latest
FORGE_DATA_PLANE_IMAGE=ghcr.io/mardash-ai/forge-data-plane:latest

# Control-plane image — `make deploy` starts it transiently to run `forge deploy` (C7,
# the zero-downtime roll). Not part of the app runtime; only the deploy uses it.
FORGE_IMAGE=ghcr.io/mardash-ai/forge-control-plane:0.6.1@sha256:482bda5ccbf88c9d8b163d18dc34b6655ae8988e77ca6c3b2bdb90ab2a98c61e

# Ingress is via Traefik (forge-os.mardash.ai) — no host port is published.
# Postgres: set POSTGRES_PASSWORD ONLY. The app's DATABASE_URL is derived from it in
# compose.prod.yaml, so the two can never drift (do NOT also set DATABASE_URL here).
POSTGRES_PASSWORD=forge

# Secrets (deploy-time). Empty ANTHROPIC_API_KEY degrades gracefully (AI drafting 503s).
ANTHROPIC_API_KEY=
FORGE_SECRETS_KEY=change-me-in-prod

# Environment for forge-os
PORT=3000
NODE_ENV=development
DATABASE_URL=postgres://forge:forge@postgres:5432/forge_os

# Activates the Planner agent (AI task drafting). Optional: without it the app
# runs fine and AI drafting shows a "set a key" message instead of crashing.
# Copy this file to `.env` (gitignored) and set your key — the web container
# reads it automatically on `./forge dev`.
# ANTHROPIC_API_KEY=sk-ant-...
